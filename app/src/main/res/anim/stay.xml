<?xml version="1.0" encoding="utf-8"?>
<!-- No-op animation for whichever activity ISN'T doing the sliding (MainActivity underneath,
     while PlaybackActivity slides up/down over it via slide_up_in.xml/slide_down_out.xml) — keeps
     it fully visible/static instead of the platform's default cross-fade. -->
<alpha xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromAlpha="1.0"
    android:toAlpha="1.0"
    android:duration="300" />
